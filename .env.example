# Database (Neon PostgreSQL)
# Get your connection string from https://neon.tech
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"
# Optional hard admin allow-lists (comma-separated).
# `ADMIN_USER_IDS` is preferred because IDs are immutable.
ADMIN_USER_IDS=""
ADMIN_EMAILS=""

# Gemini API (for all OCR and grading)
# Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key"
# AI grading workers per server process (controls parallel grading load)
AI_GRADING_CONCURRENCY="6"
# Max queued grading jobs per server process before rejecting new jobs
AI_GRADING_QUEUE_SIZE="1000"
# Mark long-stuck PROCESSING submissions as ERROR so they can be retried
AI_GRADING_STALE_PROCESSING_MS="1200000"
# How often queue maintenance checks for stale PROCESSING submissions
AI_GRADING_QUEUE_MAINTENANCE_MS="120000"
# OCR page-level parallelism inside one submission
OCR_CONCURRENCY_LIMIT="3"

# SMTP (for forgot-password / login codes)
# For Gmail with 2FA, use an App Password (not your Gmail password)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="TezTekshir <your-email@gmail.com>"
# Anti-bruteforce limits for email-code login
FORGOT_PASSWORD_IP_LIMIT="30"
FORGOT_PASSWORD_EMAIL_LIMIT="5"
VERIFY_CODE_IP_LIMIT="40"
VERIFY_CODE_EMAIL_LIMIT="10"

# Vercel Blob Storage (auto-configured when you add Blob storage in Vercel dashboard)
# BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# Click Payment Gateway
# Get credentials from https://click.uz merchant dashboard
CLICK_MERCHANT_ID=""
CLICK_SERVICE_ID=""
CLICK_SECRET_KEY=""
